Перем _Счетчик; // Число
Перем _КоличествоСбоевДоУспеха; // Число

Процедура ПриСозданииОбъекта(КоличествоСбоевДоУспеха = 0)
	_Счетчик = 0;
	_КоличествоСбоевДоУспеха = КоличествоСбоевДоУспеха;
КонецПроцедуры

Функция ПолучитьДанные() Экспорт

	_Счетчик = _Счетчик + 1;

	Если _Счетчик <= _КоличествоСбоевДоУспеха Тогда
		ВызватьИсключение "Временный сбой сервиса.";
	КонецЕсли;

	Возврат СтрШаблон("Данные получены на попытке %1", _Счетчик);

КонецФункции
