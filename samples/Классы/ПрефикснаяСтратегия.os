#Использовать resilience

Перем _Префикс; // Строка

Процедура ПриСозданииОбъекта(Префикс = "Кастомная стратегия: ")

	_Префикс = Префикс;

КонецПроцедуры

Функция Применить(Операция, Параметры = Неопределено) Экспорт

	АдаптерОперации = Новый АдаптерОперацииОтказоустойчивости();
	ПодготовленнаяОперация = АдаптерОперации.Подготовить(Операция, Параметры);

	Возврат СтрШаблон("%1%2", _Префикс, ПодготовленнаяОперация.Запустить());

КонецФункции
