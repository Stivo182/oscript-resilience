// Пользовательская стратегия обогащает результат собственным префиксом.
Стратегия = Новый ПрефикснаяСтратегия("Кастомная стратегия: ");

Пайплайн = Новый ПайплайнОтказоустойчивости()
	.ДобавитьСтратегию(Стратегия);

Результат = Пайплайн.Запустить(
	"(Имя) -> Возврат СтрШаблон(""Привет, %1!"", Имя)",
	"Мир"
);

Сообщить(Результат);
