#Область Тесты

&Тест
Процедура ТестДолжен_ВызыватьФункциональныйДелегатСКонтекстомИДополнительнымиПараметрами() Экспорт

	// Подготовка
	ТестовыеОбработчики = Новый ТестовыеОбработчикиОтказоустойчивости();
	ДополнительныеПараметры = Новый Массив();
	ДополнительныеПараметры.Добавить("marker");
	ДополнительныеПараметры.Добавить(7);

	Обработчик = Новый ОбработчикОтказоустойчивости(
		Новый Действие(ТестовыеОбработчики, "СформироватьРезультат"),
		Новый ФиксированныйМассив(ДополнительныеПараметры)
	);

	// Действие
	Результат = Обработчик.Вызвать("ctx");

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ctx|marker|7");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьСтроковуюЛямбдуСКонтекстомИДополнительнымПараметром() Экспорт

	// Подготовка
	Обработчик = Новый ОбработчикОтказоустойчивости(
		"(Контекст, Маркер) -> СтрШаблон(""%1|%2"", Контекст, Маркер)",
		"marker"
	);

	// Действие
	Результат = Обработчик.Вызвать("ctx");

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ctx|marker");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызыватьПроцедурныйОбработчикСКонтекстомИДополнительнымПараметром() Экспорт

	// Подготовка
	ТестовыеОбработчики = Новый ТестовыеОбработчикиОтказоустойчивости();
	Обработчик = Новый ОбработчикОтказоустойчивости(
		Новый Действие(ТестовыеОбработчики, "ЗапомнитьВызов"),
		"marker",
		Ложь
	);

	// Действие
	Обработчик.Вызвать("ctx");

	// Проверка
	Ожидаем.Что(ТестовыеОбработчики.Контексты().Количество(), "Количество вызовов должно быть равно 1").Равно(1);
	Ожидаем.Что(ТестовыеОбработчики.Маркеры().Количество(), "Количество маркеров должно быть равно 1").Равно(1);
	Ожидаем.Что(ТестовыеОбработчики.Контексты()[0], "Контекст должен быть равен ожидаемому значению").Равно("ctx");
	Ожидаем.Что(ТестовыеОбработчики.Маркеры()[0], "Маркер должен быть равен ожидаемому значению").Равно("marker");

КонецПроцедуры

#КонецОбласти
