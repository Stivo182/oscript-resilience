&Тест
Процедура ТестДолжен_ПередаватьОшибкуВОбещаниеАсинхронногоЗапускаПайплайна() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "ВсегдаОшибка");

	Пайплайн = Новый ПайплайнОтказоустойчивости();

	// Действие
	Обещание = Пайплайн.ЗапуститьАсинх(Операция);
	РезультатПослеОбработкиОшибки = Обещание
		.Поймать("(ДанныеОшибки) -> Возврат ""ошибка-поймана""")
		.Получить(1000);

	// Проверка
	Ожидаем.Что(РезультатПослеОбработкиОшибки, "Результат должен быть равен ожидаемому значению").Равно("ошибка-поймана");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПробрасыватьСигналПрерыванияВСинхронныйЗапускПайплайна() Экспорт

	// Подготовка
	ОсновнойСценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(ОсновнойСценарий, "Успех");

	ЗапаснойСценарий = Новый ТестовыеДействияОтказоустойчивости();

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьЗапаснойСценарий(Новый Действие(ЗапаснойСценарий, "УспехСКонтекстомОшибкиЗапасногоСценария"));

	СигналПрерыванияОперации = Новый СигналПрерыванияОперации();
	СигналПрерыванияОперации.ЗапроситьПрерывание("Остановлено тестом.");

	// Действие
	Ожидаем
		.Что(Пайплайн, "Вызов метода пайплайна должен выбрасывать ожидаемое исключение")
		.Метод("Запустить", ПомощникТестирования.ПараметрыИсполнения(Операция, Неопределено, СигналПрерыванияОперации))
		.ВыбрасываетИсключение("Остановлено тестом.");

	// Проверка
	Ожидаем.Что(ОсновнойСценарий.СчетчикВызовов(), "Основная операция не должна запускаться").Равно(0);
	Ожидаем.Что(ЗапаснойСценарий.СчетчикВызовов(), "Запасной сценарий не должен запускаться").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПробрасыватьСигналПрерыванияВАсинхронныйЗапускПайплайна() Экспорт

	Если Не ТекущаяВерсияOneScriptБольше1x() Тогда
		Возврат;
	КонецЕсли;

	// Подготовка
	ОсновнойСценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(ОсновнойСценарий, "Успех");

	ЗапаснойСценарий = Новый ТестовыеДействияОтказоустойчивости();

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьЗапаснойСценарий(Новый Действие(ЗапаснойСценарий, "УспехСКонтекстомОшибкиЗапасногоСценария"));

	СигналПрерыванияОперации = Новый СигналПрерыванияОперации();
	СигналПрерыванияОперации.ЗапроситьПрерывание("Остановлено тестом.");

	ПараметрыПолучения = Новый Массив();
	ПараметрыПолучения.Добавить(1000);

	// Действие
	Обещание = Пайплайн.ЗапуститьАсинх(Операция, , СигналПрерыванияОперации);

	// Проверка
	Ожидаем
		.Что(Обещание, "Получение результата обещания должно выбрасывать ожидаемое исключение")
		.Метод("Получить", ПараметрыПолучения)
		.ВыбрасываетИсключение("Остановлено тестом.");

	Ожидаем.Что(ОсновнойСценарий.СчетчикВызовов(), "Основная операция не должна запускаться").Равно(0);
	Ожидаем.Что(ЗапаснойСценарий.СчетчикВызовов(), "Запасной сценарий не должен запускаться").Равно(0);

КонецПроцедуры

