&Тест
Процедура ТестДолжен_ПрименятьПользовательскиеСтратегииВПорядкеДобавления() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");
	ВнешняяСтратегия = Новый ТестоваяПользовательскаяСтратегия("outer:");
	ВнутренняяСтратегия = Новый ТестоваяПользовательскаяСтратегия("inner:");

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьСтратегию(ВнешняяСтратегия)
		.ДобавитьСтратегию(ВнутренняяСтратегия);

	// Действие
	Результат = Пайплайн.Запустить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен отражать порядок применения стратегий")
		.Равно("outer:inner:ok");
	Ожидаем.Что(ВнешняяСтратегия.СчетчикПрименений(), "Внешняя стратегия должна примениться один раз")
		.Равно(1);
	Ожидаем.Что(ВнутренняяСтратегия.СчетчикПрименений(), "Внутренняя стратегия должна примениться один раз")
		.Равно(1);
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Пользовательская операция должна выполниться один раз")
		.Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_УчитыватьПорядокПовтораИПредохранителяВПайплайне() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "ВсегдаОшибка");

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьПовтор(2, 0)
		.ДобавитьПредохранитель(1, 1000);

	// Действие и Проверка
	Ожидаем
		.Что(Пайплайн, "Вызов метода пайплайна должен выбрасывать ожидаемое исключение")
		.Метод("Запустить", ПараметрыОперации(Операция))
		.ВыбрасываетИсключение("Предохранитель временно разомкнут");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Пользовательская операция должна выполниться только один раз")
		.Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_УчитыватьПорядокПредохранителяИПовтораВПайплайне() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "ВсегдаОшибка");

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьПредохранитель(1, 1000)
		.ДобавитьПовтор(2, 0);

	// Действие и Проверка
	Ожидаем
		.Что(Пайплайн, "Первый вызов пайплайна должен завершаться ошибкой пользовательской операции")
		.Метод("Запустить", ПараметрыОперации(Операция))
		.ВыбрасываетИсключение("Всегда ошибка.");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Пользовательская операция должна выполниться три раза")
		.Равно(3);

	Ожидаем
		.Что(Пайплайн, "Второй вызов пайплайна должен отклоняться разомкнутым предохранителем")
		.Метод("Запустить", ПараметрыОперации(Операция))
		.ВыбрасываетИсключение("Предохранитель временно разомкнут");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "После размыкания предохранителя новых вызовов операции быть не должно")
		.Равно(3);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВозвращатьЗапаснойРезультатПриТаймаутеВЦепочкеПайплайна() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(300);
	Операция = Новый Действие(Сценарий, "Долгое");

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьЗапаснойСценарий("(КонтекстОшибки) -> Возврат ""timeout:fallback""")
		.ДобавитьТаймаут(20);

	// Действие
	Результат = Пайплайн.Запустить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен запасному значению после таймаута")
		.Равно("timeout:fallback");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Пользовательская операция должна быть запущена один раз")
		.Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьНачальныеСтратегииВКонструктореПайплайна() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	ОсновноеДействие = Новый Действие(Сценарий, "Нестабильное");

	РезервныйСценарий = Новый ТестовыеДействияОтказоустойчивости();
	РезервныйСценарий.УстановитьРезультат("запасной-результат");

	Стратегии = Новый Массив();
	Стратегии.Добавить(Новый СтратегияЗапасногоСценария(Новый Действие(РезервныйСценарий, "УспехСКонтекстомОшибкиЗапасногоСценария")));
	Стратегии.Добавить(Новый СтратегияПовтора(2));

	Пайплайн = Новый ПайплайнОтказоустойчивости(Стратегии);

	// Действие
	Результат = Пайплайн.Запустить(ОсновноеДействие);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("запасной-результат");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 3").Равно(3);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВалидироватьСтратегиюПриДобавленииВПайплайн() Экспорт

