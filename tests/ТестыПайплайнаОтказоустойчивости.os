&Тест
Процедура ТестДолжен_ЗапускатьПайплайнСоСтроковойЛямбдойКакОперацией() Экспорт

	// Подготовка
	ПараметрыЛямбды = Новый Массив();
	ПараметрыЛямбды.Добавить("left");
	ПараметрыЛямбды.Добавить("right");

	Пайплайн = Новый ПайплайнОтказоустойчивости();

	// Действие
	Результат = Пайплайн.Запустить(
		"(ПервыйПараметр, ВторойПараметр) -> Возврат СтрШаблон(""%1:%2"", ПервыйПараметр, ВторойПараметр)",
		ПараметрыЛямбды
	);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("left:right");

КонецПроцедуры

