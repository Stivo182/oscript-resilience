&Тест
Процедура ТестДолжен_ПоддерживатьПользовательскуюСтратегиюВПайплайне() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "УспехСПараметрами");
	ПользовательскаяСтратегия = Новый ТестоваяПользовательскаяСтратегия("custom:");

	ПараметрыОперации = Новый Массив();
	ПараметрыОперации.Добавить("left");
	ПараметрыОперации.Добавить("right");

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьСтратегию(ПользовательскаяСтратегия);

	// Действие
	Результат = Пайплайн.Запустить(Операция, ПараметрыОперации);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("custom:left:right");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(ПользовательскаяСтратегия.СчетчикПрименений(), "Значение должно быть равно 1").Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьНачальныеСтратегииВКонструктореПайплайна() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	ОсновноеДействие = Новый Действие(Сценарий, "Нестабильное");

	РезервныйСценарий = Новый ТестовыеДействияОтказоустойчивости();
	РезервныйСценарий.УстановитьРезультат("запасной-результат");

	Стратегии = Новый Массив();
	Стратегии.Добавить(Новый СтратегияЗапасногоСценария(Новый Действие(РезервныйСценарий, "УспехСКонтекстомОшибкиЗапасногоСценария")));
	Стратегии.Добавить(Новый СтратегияПовтора(2));

	Пайплайн = Новый ПайплайнОтказоустойчивости(Стратегии);

	// Действие
	Результат = Пайплайн.Запустить(ОсновноеДействие);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("запасной-результат");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 3").Равно(3);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВалидироватьСтратегиюПриДобавленииВПайплайн() Экспорт

	// Подготовка
	Пайплайн = Новый ПайплайнОтказоустойчивости();

	// Действие и Проверка
	Ожидаем
		.Что(Пайплайн, "Вызов метода пайплайна должен выбрасывать ожидаемое исключение")
		.Метод("ДобавитьСтратегию", ПараметрыОперации(Неопределено))
		.ВыбрасываетИсключение("Стратегия не должна быть Неопределено.");

	Ожидаем
		.Что(Пайплайн, "Вызов метода пайплайна должен выбрасывать ожидаемое исключение")
		.Метод("ДобавитьСтратегию", ПараметрыОперации(Новый ТестовыеДействияОтказоустойчивости()))
		.ВыбрасываетИсключение("Стратегия должна поддерживать метод Применить.");

КонецПроцедуры

