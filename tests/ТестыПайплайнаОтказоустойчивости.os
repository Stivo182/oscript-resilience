&Тест
Процедура ТестДолжен_ЗапускатьПайплайнАсинхронно() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(50);
	Операция = Новый Действие(Сценарий, "Успех");

	Пайплайн = Новый ПайплайнОтказоустойчивости();

	// Действие
	Обещание = Пайплайн.ЗапуститьАсинх(Операция);
	Результат = Обещание.Получить(1000);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьОшибкуВОбещаниеАсинхронногоЗапускаПайплайна() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "ВсегдаОшибка");

	Пайплайн = Новый ПайплайнОтказоустойчивости();

	// Действие
	Обещание = Пайплайн.ЗапуститьАсинх(Операция);
	РезультатПослеОбработкиОшибки = Обещание
		.Поймать("ДанныеОшибки -> ""ошибка-поймана""")
		.Получить(1000);

	// Проверка
	Ожидаем.Что(РезультатПослеОбработкиОшибки, "Результат должен быть равен ожидаемому значению").Равно("ошибка-поймана");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьПараметрыЧерезПайплайн() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "УспехСПараметрами");
	
	ПараметрыОперации = Новый Массив();
	ПараметрыОперации.Добавить("left");
	ПараметрыОперации.Добавить("right");

	Пайплайн = Новый ПайплайнОтказоустойчивости();
	Пайплайн.ДобавитьПовтор(0, 0);

	// Действие
	Результат = Пайплайн.Запустить(Операция, ПараметрыОперации);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("left:right");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

