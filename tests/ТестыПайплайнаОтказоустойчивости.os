&Тест
Процедура ТестДолжен_ДобавлятьОграничениеВызововЧерезУпрощенныйМетодСПравильнымиПараметрами() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	Пайплайн = Новый ПайплайнОтказоустойчивости();
	Пайплайн.ДобавитьОграничениеВызовов(1, 1000);

	// Действие
	Результат = Пайплайн.Запустить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем
		.Что(Пайплайн, "Вызов метода пайплайна должен выбрасывать ожидаемое исключение")
		.Метод("Запустить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Превышен лимит вызовов");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ДобавлятьТаймаутЧерезУпрощенныйМетодСПравильнымиПараметрами() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(300);

	Операция = Новый Действие(Сценарий, "Долгое");

	Пайплайн = Новый ПайплайнОтказоустойчивости();
	Пайплайн.ДобавитьТаймаут(20);

	// Действие и Проверка
	Ожидаем
		.Что(Пайплайн, "Вызов метода пайплайна должен выбрасывать ожидаемое исключение")
		.Метод("Запустить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("таймаут");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьУпрощенныеМетодыПайплайна() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	Пайплайн = Новый ПайплайнОтказоустойчивости()
		.ДобавитьПредохранитель(2, 500)
		.ДобавитьОграничениеПараллелизма(2, 1)
		.ДобавитьОграничениеВызовов(5, 1000)
		.ДобавитьПовтор(1, 0)
		.ДобавитьЗапаснойСценарий()
		.ДобавитьТаймаут(1000);

	// Действие
	Результат = Пайплайн.Запустить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПараметрыОперации(Значение)

	ПараметрыМетода = Новый Массив();
	ПараметрыМетода.Добавить(Значение);

	Возврат ПараметрыМетода;

КонецФункции

Функция ТекущаяВерсияOneScriptБольше1x()

	Возврат Число(Лев(Новый СистемнаяИнформация().Версия, 1)) > 1;

КонецФункции

#КонецОбласти
