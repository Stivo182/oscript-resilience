	Ожидаем.Что(ДлительностиВыполнения[0]).БольшеИлиРавно(100);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьСледующуюПопыткуИОставшиесяПопыткиВКонтекстПовтора() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);

	КолбэкиRetry = Новый ТестовыеКолбэкиRetry();

	Стратегия = Новый СтратегияRetry();
	Стратегия.УстановитьМаксимумПовторов(2);
	Стратегия.УстановитьЗадержку(0);
	Стратегия.УстановитьОбработчикПовтора(Новый Действие(КолбэкиRetry, "ПослеПовтора"));
	
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	СледующиеПопытки = КолбэкиRetry.СледующиеПопытки();
	ПопытокОсталось = КолбэкиRetry.ПопытокОсталось();

	Ожидаем.Что(СледующиеПопытки.Количество()).Равно(2);
	Ожидаем.Что(ПопытокОсталось.Количество()).Равно(2);
	Ожидаем.Что(СледующиеПопытки[0]).Равно(1);
	Ожидаем.Что(СледующиеПопытки[1]).Равно(2);
	Ожидаем.Что(ПопытокОсталось[0]).Равно(2);
	Ожидаем.Что(ПопытокОсталось[1]).Равно(1);

КонецПроцедуры

