&Тест
Процедура ТестДолжен_ПовторятьОперациюДоУспеха() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(2);

	Стратегия = Новый СтратегияRetry(3);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов()).Равно(3);

КонецПроцедуры

