&Тест
Процедура ТестДолжен_ДобавлятьСлучайныйРазбросКЗадержке() Экспорт

	// Подготовка
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);

	КолбэкиRetry = Новый ТестовыеКолбэкиRetry();

	Стратегия = Новый СтратегияRetry();
	Стратегия.УстановитьМаксимумПовторов(1);
	Стратегия.УстановитьЗадержку(100);
	Стратегия.ИспользоватьРазбросЗадержки();
	Стратегия.УстановитьОбработчикПовтора(Новый Действие(КолбэкиRetry, "ПослеПовтора"));
	
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Задержки = КолбэкиRetry.Задержки();

	Ожидаем.Что(Задержки.Количество()).Равно(1);
	Ожидаем.Что(Задержки[0]).БольшеИлиРавно(75);
	Ожидаем.Что(Задержки[0]).МеньшеИлиРавно(125);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПараметрыИсполнения(Операция, ПараметрыОперации = Неопределено)

	ПараметрыМетода = Новый Массив();
	ПараметрыМетода.Добавить(Операция);
	Если ПараметрыОперации <> Неопределено Тогда
		ПараметрыМетода.Добавить(ПараметрыОперации);
	КонецЕсли;

	Возврат ПараметрыМетода;

КонецФункции

#КонецОбласти
