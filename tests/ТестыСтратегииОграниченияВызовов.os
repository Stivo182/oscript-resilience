#Область Тесты

&Тест
Процедура ТестДолжен_ОграничиватьВызовыПоЛимитуВызовов() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияВызовов(2, 200);
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие и Проверка
	Ожидаем.Что(Стратегия.Применить(Операция), "Значение должно быть равно ожидаемому значению").Равно("ok");
	Ожидаем.Что(Стратегия.Применить(Операция), "Значение должно быть равно ожидаемому значению").Равно("ok");

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Превышен лимит вызовов");

	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 2").Равно(2);

КонецПроцедуры

&Тест
Процедура ТестДолжен_СбрасыватьЛимитВызововПослеИстеченияИнтервала() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияВызовов(1, 120);
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие и Проверка
	Ожидаем.Что(Стратегия.Применить(Операция), "Значение должно быть равно ожидаемому значению").Равно("ok");
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Превышен лимит вызовов");

	Приостановить(140);

	Ожидаем.Что(Стратегия.Применить(Операция), "Значение должно быть равно ожидаемому значению").Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 2").Равно(2);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПрименятьУстановленныеЛимитВызововИИнтервалЛимита() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияВызовов(10, 1000)
		.УстановитьЛимитВызовов(1)
		.УстановитьИнтервалЛимита(120);

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие и Проверка
	Ожидаем.Что(Стратегия.Применить(Операция), "Значение должно быть равно ожидаемому значению").Равно("ok");

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Превышен лимит вызовов");

	Ожидаем.Что(Стратегия.ЛимитВызовов(), "Лимит вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.ИнтервалЛимита(), "Интервал лимита должен быть равен 120").Равно(120);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВозвращатьКоличествоВызововЗаТекущийИнтервал() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияВызовов(2, 120);

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие
	НачальноеКоличествоВызовов = Стратегия.КоличествоВызововЗаИнтервал();
	Стратегия.Применить(Операция);
	КоличествоПослеПервогоВызова = Стратегия.КоличествоВызововЗаИнтервал();
	Стратегия.Применить(Операция);
	КоличествоПослеВторогоВызова = Стратегия.КоличествоВызововЗаИнтервал();

	Приостановить(140);
	КоличествоПослеИстеченияИнтервала = Стратегия.КоличествоВызововЗаИнтервал();

	// Проверка
	Ожидаем.Что(НачальноеКоличествоВызовов, "Значение должно быть равно 0").Равно(0);
	Ожидаем.Что(КоличествоПослеПервогоВызова, "Значение должно быть равно 1").Равно(1);
	Ожидаем.Что(КоличествоПослеВторогоВызова, "Значение должно быть равно 2").Равно(2);
	Ожидаем.Что(КоличествоПослеИстеченияИнтервала, "Значение должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_СбрасыватьТекущееСостояниеЛимитаПоМетодуСбросить() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияВызовов(1, 1000);

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие
	Стратегия.Применить(Операция);
	КоличествоДоСброса = Стратегия.КоличествоВызововЗаИнтервал();
	Стратегия.Сбросить();
	КоличествоПослеСброса = Стратегия.КоличествоВызововЗаИнтервал();
	РезультатПослеСброса = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(КоличествоДоСброса, "Значение должно быть равно 1").Равно(1);
	Ожидаем.Что(КоличествоПослеСброса, "Значение должно быть равно 0").Равно(0);
	Ожидаем.Что(РезультатПослеСброса, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Стратегия.КоличествоВызововЗаИнтервал(), "Количество вызовов за интервал должно быть равно 1").Равно(1);
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 2").Равно(2);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызыватьОбработчикПревышенияЛимитаПередИсключением() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияВызовов();

	Стратегия = Новый СтратегияОграниченияВызовов(1, 200);
	Стратегия.УстановитьОбработчикПревышенияЛимита(Новый Действие(Колбэки, "ПослеПревышенияЛимита"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие и Проверка
	Ожидаем.Что(Стратегия.Применить(Операция), "Значение должно быть равно ожидаемому значению").Равно("ok");

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Превышен лимит вызовов");

	Ожидаем.Что(Колбэки.ОставшеесяВремя(), "Список значений оставшегося времени должен иметь длину 1").ИмеетДлину(1);
	Ожидаем.Что(Колбэки.ЛимитыВызовов()[0], "Значение должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.ИнтервалыЛимита()[0], "Значение должно быть равно 200").Равно(200);
	Ожидаем.Что(Колбэки.КоличествоВызововЗаИнтервал()[0], "Количество вызовов за интервал должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.ОставшеесяВремя()[0], "Оставшееся время должно быть больше или равно 0").БольшеИлиРавно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьДополнительныеПараметрыВДелегатОбработчикаПревышенияЛимита() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияВызовов();

	Стратегия = Новый СтратегияОграниченияВызовов(1, 200);
	Стратегия.УстановитьОбработчикПревышенияЛимита(
		Новый Действие(Колбэки, "ПослеПревышенияЛимитаСМаркером"),
		"marker"
	);

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие
	Стратегия.Применить(Операция);

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Превышен лимит вызовов");

	// Проверка
	Ожидаем.Что(Колбэки.Маркеры().Количество(), "Количество маркеров должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.Маркеры()[0], "Маркер должен быть равен ожидаемому значению").Равно("marker");

КонецПроцедуры

// Флаки-тест
&Тест
Процедура ТестДолжен_РазрешатьТолькоОдинПараллельныйВызовПриЛимитеОдин() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияВызовов(1, 1000);
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");
	
	КоличествоПараллельныхЗадач = 15;
	
	// Действие
	Задачи = ПомощникТестирования.ЗапуститьПараллельныеВызовыСтратегии(
		Стратегия,
		Операция,
		КоличествоПараллельныхЗадач
	);

	Статистика = СобратьСтатистикуФоновыхЗаданий(Задачи, "Превышен лимит вызовов");

	// Проверка
	Ожидаем.Что(Статистика.Успешных, "Количество успешных вызовов должно быть равно 1").Равно(1);
	Ожидаем
		.Что(Статистика.ОжидаемыхОшибок, "Количество ожидаемых ошибок должно быть равно ожидаемому значению")
		.Равно(КоличествоПараллельныхЗадач - 1);
	Ожидаем.Что(Статистика.НеожиданныеОшибки.Количество(), "Количество неожиданных ошибок должно быть равно 0").Равно(0);
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СобратьСтатистикуФоновыхЗаданий(Задачи, ОжидаемыйТекстОшибки)

	Статистика = Новый Структура("Успешных, ОжидаемыхОшибок, НеожиданныеОшибки", 0, 0, Новый Массив());

	Для Каждого Задание Из Задачи Цикл
		Если Не Задание.ОжидатьЗавершения(5000) Тогда
			ВызватьИсключение "Фоновое задание не завершилось вовремя.";
		КонецЕсли;

		Если Задание.ИнформацияОбОшибке = Неопределено Тогда
			Статистика.Успешных = Статистика.Успешных + 1;
			Продолжить;
		КонецЕсли;

		ТекстОшибки = ПодробноеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
		Если СтрНайти(ТекстОшибки, ОжидаемыйТекстОшибки) > 0 Тогда
			Статистика.ОжидаемыхОшибок = Статистика.ОжидаемыхОшибок + 1;
		Иначе
			Статистика.НеожиданныеОшибки.Добавить(ТекстОшибки);
		КонецЕсли;
	КонецЦикла;

	Возврат Статистика;

КонецФункции

#КонецОбласти
