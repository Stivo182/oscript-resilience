#Область Тесты

&Тест
Процедура ТестДолжен_ВозвращатьИПрименятьУстановленныеОграниченияПараллелизма() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(2)
		.УстановитьЛимитПараллелизма(4)
		.УстановитьЛимитОчереди(3);

	// Проверка
	Ожидаем.Что(Стратегия.ЛимитПараллелизма()).Равно(4);
	Ожидаем.Что(Стратегия.ЛимитОчереди()).Равно(3);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВалидироватьЛимитПараллелизма() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);

	ПараметрыЛимита = Новый Массив();
	ПараметрыЛимита.Добавить(0);

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия)
		.Метод("УстановитьЛимитПараллелизма", ПараметрыЛимита)
		.ВыбрасываетИсключение("Лимит параллелизма должен быть больше 0.");

КонецПроцедуры

