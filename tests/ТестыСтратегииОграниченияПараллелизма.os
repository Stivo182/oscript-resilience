&Тест
Процедура ТестДолжен_ОтклонятьВложенныйВызовПриИсчерпанииЛимитаПараллелизма() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомОграниченияПараллелизма(Стратегия, ВложеннаяОперация);
	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем
		.Что(ПробноеДействие.ТекстВнутреннейОшибки(), "Текст внутренней ошибки должен содержать ожидаемый текст")
		.Содержит("Превышен лимит параллелизма");
	Ожидаем.Что(СценарийУспеха.СчетчикВызовов(), "Счетчик вызовов должен быть равен 0").Равно(0);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ОсвобождатьСлотПослеИсключенияОперации() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);

	СценарийОшибки = Новый ТестовыеДействияОтказоустойчивости();
	ОперацияОшибки = Новый Действие(СценарийОшибки, "ВсегдаОшибка");

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ОперацияУспеха = Новый Действие(СценарийУспеха, "Успех");

	// Действие
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(ОперацияОшибки))
		.ВыбрасываетИсключение("Всегда ошибка.");

	КоличествоПослеОшибки = Стратегия.КоличествоВыполняющихся();
	Результат = Стратегия.Применить(ОперацияУспеха);

	// Проверка
	Ожидаем.Что(КоличествоПослеОшибки, "Количество выполняющихся операций после ошибки должно быть равно 0").Равно(0);
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);
	Ожидаем.Что(СценарийУспеха.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызыватьОбработчикПереполненияПередИсключением() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияПараллелизма();

	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Стратегия.УстановитьОбработчикПереполнения(Новый Действие(Колбэки, "ПослеПереполнения"));

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомОграниченияПараллелизма(Стратегия, ВложеннаяОперация);
	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Колбэки.ЛимитыПараллелизма().Количество(), "Количество значений лимита параллелизма должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыПараллелизма()[0], "Лимит параллелизма должен быть равен 1").Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыОчереди()[0], "Лимит очереди должен быть равен 0").Равно(0);
	Ожидаем.Что(Колбэки.КоличествоВыполняющихся()[0], "Количество выполняющихся операций должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.КоличествоОжидающих()[0], "Количество ожидающих операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьСтроковуюЛямбдуДляОбработчикаПереполнения() Экспорт

