	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомОграниченияПараллелизма(Стратегия, ВложеннаяОперация);
	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(ПробноеДействие.ТекстВнутреннейОшибки()).Содержит("Обработчик переполнения вызван");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВозвращатьКоличествоВыполняющихсяВоВремяЗанятогоСлота() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(500);
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие
	Задача = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция)
	);

	КоличествоСталоЕдиницей = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача <> Неопределено).Равно(Истина);
	Ожидаем.Что(КоличествоСталоЕдиницей).Равно(Истина);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(1);

	Приостановить(600);

	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ЗапрещатьИзменениеЛимитаВоВремяВыполненияОперации() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(500);
	Операция = Новый Действие(Сценарий, "Успех");

	НовыйЛимит = Новый Массив();
	НовыйЛимит.Добавить(2);

	// Действие
	Задача = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция)
	);

	КоличествоСталоЕдиницей = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача <> Неопределено).Равно(Истина);
	Ожидаем.Что(КоличествоСталоЕдиницей).Равно(Истина);

	Ожидаем
		.Что(Стратегия)
		.Метод("УстановитьЛимитПараллелизма", НовыйЛимит)
		.ВыбрасываетИсключение("Нельзя менять ограничения параллелизма во время выполнения или ожидания операций.");

	Приостановить(600);

	Ожидаем.Что(Стратегия.ЛимитПараллелизма()).Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_РазрешатьНеБолееДвухПараллельныхОперацийПриЛимитеДва() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(2);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(500);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийВторойОперации.УстановитьЗадержку(500);
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	СценарийТретьейОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция3 = Новый Действие(СценарийТретьейОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОбаСлотаЗаняты = ДождатьсяКоличествоВыполняющихся(Стратегия, 2);

	// Проверка
	Ожидаем.Что(ПервыйСлотЗанят).Равно(Истина);
	Ожидаем.Что(ОбаСлотаЗаняты).Равно(Истина);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(2);

	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция3))
		.ВыбрасываетИсключение("Превышен лимит параллелизма");

	Ожидаем.Что(СценарийТретьейОперации.СчетчикВызовов()).Равно(0);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено).Равно(Истина);

	Ожидаем.Что(СценарийПервойОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(СценарийВторойОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПомещатьОперациюВОчередьИЗапускатьЕеПослеОсвобожденияСлота() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 1);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(400);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОперацияПоставленаВОчередь = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача1 <> Неопределено).Равно(Истина);
	Ожидаем.Что(Задача2 <> Неопределено).Равно(Истина);
	Ожидаем.Что(ПервыйСлотЗанят).Равно(Истина);
	Ожидаем.Что(ОперацияПоставленаВОчередь).Равно(Истина);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(1);
	Ожидаем.Что(Стратегия.КоличествоОжидающих()).Равно(1);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(СценарийПервойОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(СценарийВторойОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ОтклонятьОперациюПриПереполненииОчереди() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияПараллелизма();

	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 1);
	Стратегия.УстановитьОбработчикПереполнения(Новый Действие(Колбэки, "ПослеПереполнения"));

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(400);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	СценарийТретьейОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция3 = Новый Действие(СценарийТретьейОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОчередьЗаполнена = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	// Проверка
	Ожидаем.Что(ПервыйСлотЗанят).Равно(Истина);
	Ожидаем.Что(ОчередьЗаполнена).Равно(Истина);

	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция3))
		.ВыбрасываетИсключение("Превышен лимит параллелизма");

	Ожидаем.Что(Колбэки.ЛимитыПараллелизма().Количество()).Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыПараллелизма()[0]).Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыОчереди()[0]).Равно(1);
	Ожидаем.Что(Колбэки.КоличествоВыполняющихся()[0]).Равно(1);
	Ожидаем.Что(Колбэки.КоличествоОжидающих()[0]).Равно(1);
	Ожидаем.Что(СценарийТретьейОперации.СчетчикВызовов()).Равно(0);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ОбслуживатьОчередьВПорядкеПоступления() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 2);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(300);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийВторойОперации.УстановитьЗадержку(200);
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	СценарийТретьейОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция3 = Новый Действие(СценарийТретьейОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ПервыйОжидает = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	Задача3 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция3)
	);

	ВторойОжидает = ДождатьсяКоличествоОжидающих(Стратегия, 2);

	// Проверка
	Ожидаем.Что(ПервыйСлотЗанят).Равно(Истина);
	Ожидаем.Что(ПервыйОжидает).Равно(Истина);
	Ожидаем.Что(ВторойОжидает).Равно(Истина);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача3.ОжидатьЗавершения(50)).Равно(Ложь);

	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача3.ОжидатьЗавершения(5000)).Равно(Истина);

	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(Задача3.ИнформацияОбОшибке = Неопределено).Равно(Истина);
	Ожидаем.Что(СценарийПервойОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(СценарийВторойОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(СценарийТретьейОперации.СчетчикВызовов()).Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ЗапрещатьИзменениеОграниченийВоВремяОжиданияВОчерди() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 1);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(400);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	НовыйЛимитПараллелизма = Новый Массив();
	НовыйЛимитПараллелизма.Добавить(2);

	НовыйЛимитОчереди = Новый Массив();
	НовыйЛимитОчереди.Добавить(2);

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОперацияПоставленаВОчередь = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача1 <> Неопределено).Равно(Истина);
	Ожидаем.Что(Задача2 <> Неопределено).Равно(Истина);
	Ожидаем.Что(ПервыйСлотЗанят).Равно(Истина);
	Ожидаем.Что(ОперацияПоставленаВОчередь).Равно(Истина);

	Ожидаем
		.Что(Стратегия)
		.Метод("УстановитьЛимитПараллелизма", НовыйЛимитПараллелизма)
		.ВыбрасываетИсключение("Нельзя менять ограничения параллелизма во время выполнения или ожидания операций.");

	Ожидаем
		.Что(Стратегия)
		.Метод("УстановитьЛимитОчереди", НовыйЛимитОчереди)
		.ВыбрасываетИсключение("Нельзя менять ограничения параллелизма во время выполнения или ожидания операций.");

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000)).Равно(Истина);
	Ожидаем.Что(Стратегия.ЛимитПараллелизма()).Равно(1);
	Ожидаем.Что(Стратегия.ЛимитОчереди()).Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих()).Равно(0);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДождатьсяКоличествоВыполняющихся(Стратегия, ОжидаемоеКоличество, Таймаут = 1000)

	МоментНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаОжидания < Таймаут Цикл
		Если Стратегия.КоличествоВыполняющихся() = ОжидаемоеКоличество Тогда
			Возврат Истина;
		КонецЕсли;

		Приостановить(10);
	КонецЦикла;

	Возврат Ложь;

КонецФункции

Функция ДождатьсяКоличествоОжидающих(Стратегия, ОжидаемоеКоличество, Таймаут = 1000)

	МоментНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаОжидания < Таймаут Цикл
		Если Стратегия.КоличествоОжидающих() = ОжидаемоеКоличество Тогда
			Возврат Истина;
		КонецЕсли;

		Приостановить(10);
	КонецЦикла;

	Возврат Ложь;

КонецФункции

#КонецОбласти
