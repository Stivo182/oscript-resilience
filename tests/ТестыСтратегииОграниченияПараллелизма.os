&Тест
Процедура ТестДолжен_ОбслуживатьОчередьВПорядкеПоступления() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 2);

	СценарийПервойОперации = Новый ТестовоеУправляемоеДействие();
	Операция1 = Новый Действие(СценарийПервойОперации, "ВыполнитьУправляемо");

	СценарийВторойОперации = Новый ТестовоеУправляемоеДействие();
	Операция2 = Новый Действие(СценарийВторойОперации, "ВыполнитьУправляемо");

	СценарийТретьейОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция3 = Новый Действие(СценарийТретьейОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ПервыйОжидает = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	Задача3 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция3)
	);

	ВторойОжидает = ДождатьсяКоличествоОжидающих(Стратегия, 2);

	// Проверка
	Ожидаем.Что(ПервыйСлотЗанят, "Первый слот должен быть занят").ЭтоИстина();
	Ожидаем.Что(ПервыйОжидает, "Первая операция должна ожидать освобождения слота").ЭтоИстина();
	Ожидаем.Что(ВторойОжидает, "Вторая операция должна ожидать освобождения слота").ЭтоИстина();

	СценарийПервойОперации.Разрешить();
	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	ВтораяОперацияНачалась = ДождатьсяНачалаДействия(СценарийВторойОперации);
	Ожидаем.Что(ВтораяОперацияНачалась, "Вторая операция должна начать выполняться после первой").ЭтоИстина();
	Ожидаем.Что(Задача3.ОжидатьЗавершения(50), "Фоновое задание не должно завершиться").ЭтоЛожь();

	СценарийВторойОперации.Разрешить();
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача3.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();

	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(Задача3.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(СценарийПервойОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(СценарийВторойОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(СценарийТретьейОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих(), "Количество ожидающих операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ЗапрещатьИзменениеОграниченийВоВремяОжиданияВОчерди() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 1);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(400);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	НовыйЛимитПараллелизма = Новый Массив();
	НовыйЛимитПараллелизма.Добавить(2);

	НовыйЛимитОчереди = Новый Массив();
	НовыйЛимитОчереди.Добавить(2);

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОперацияПоставленаВОчередь = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача1 <> Неопределено, "Фоновое задание должно быть создано").ЭтоИстина();
	Ожидаем.Что(Задача2 <> Неопределено, "Фоновое задание должно быть создано").ЭтоИстина();
	Ожидаем.Что(ПервыйСлотЗанят, "Первый слот должен быть занят").ЭтоИстина();
	Ожидаем.Что(ОперацияПоставленаВОчередь, "Операция должна быть поставлена в очередь").ЭтоИстина();

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("УстановитьЛимитПараллелизма", НовыйЛимитПараллелизма)
		.ВыбрасываетИсключение("Нельзя менять ограничения параллелизма во время выполнения или ожидания операций.");

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("УстановитьЛимитОчереди", НовыйЛимитОчереди)
		.ВыбрасываетИсключение("Нельзя менять ограничения параллелизма во время выполнения или ожидания операций.");

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Стратегия.ЛимитПараллелизма(), "Лимит параллелизма должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.ЛимитОчереди(), "Лимит очереди должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих(), "Количество ожидающих операций должно быть равно 0").Равно(0);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДождатьсяКоличествоВыполняющихся(Стратегия, ОжидаемоеКоличество, Таймаут = 1000)

	МоментНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаОжидания < Таймаут Цикл
		Если Стратегия.КоличествоВыполняющихся() = ОжидаемоеКоличество Тогда
			Возврат Истина;
		КонецЕсли;

		Приостановить(10);
	КонецЦикла;

	Возврат Ложь;

КонецФункции

Функция ДождатьсяКоличествоОжидающих(Стратегия, ОжидаемоеКоличество, Таймаут = 1000)

	МоментНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаОжидания < Таймаут Цикл
		Если Стратегия.КоличествоОжидающих() = ОжидаемоеКоличество Тогда
			Возврат Истина;
		КонецЕсли;

		Приостановить(10);
	КонецЦикла;

	Возврат Ложь;

КонецФункции

Функция ДождатьсяНачалаДействия(Действие, Таймаут = 1000)

	МоментНачалаОжидания = ТекущаяУниверсальнаяДатаВМиллисекундах();

	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментНачалаОжидания < Таймаут Цикл
		Если Действие.Начато() Тогда
			Возврат Истина;
		КонецЕсли;

		Приостановить(10);
	КонецЦикла;

	Возврат Ложь;

КонецФункции

#КонецОбласти
