&Тест
Процедура ТестДолжен_ОтклонятьВложенныйВызовПриИсчерпанииЛимитаПараллелизма() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомОграниченияПараллелизма(Стратегия, ВложеннаяОперация);
	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(ПробноеДействие.ТекстВнутреннейОшибки()).Содержит("Превышен лимит параллелизма");
	Ожидаем.Что(СценарийУспеха.СчетчикВызовов()).Равно(0);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ОсвобождатьСлотПослеИсключенияОперации() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);

	СценарийОшибки = Новый ТестовыеДействияОтказоустойчивости();
	ОперацияОшибки = Новый Действие(СценарийОшибки, "ВсегдаОшибка");

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ОперацияУспеха = Новый Действие(СценарийУспеха, "Успех");

	// Действие
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(ОперацияОшибки))
		.ВыбрасываетИсключение("Всегда ошибка.");

	КоличествоПослеОшибки = Стратегия.КоличествоВыполняющихся();
	Результат = Стратегия.Применить(ОперацияУспеха);

	// Проверка
	Ожидаем.Что(КоличествоПослеОшибки).Равно(0);
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся()).Равно(0);
	Ожидаем.Что(СценарийУспеха.СчетчикВызовов()).Равно(1);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызыватьОбработчикПереполненияПередИсключением() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияПараллелизма();

	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Стратегия.УстановитьОбработчикПереполнения(Новый Действие(Колбэки, "ПослеПереполнения"));

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомОграниченияПараллелизма(Стратегия, ВложеннаяОперация);
	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(Колбэки.ЛимитыПараллелизма().Количество()).Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыПараллелизма()[0]).Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыОчереди()[0]).Равно(0);
	Ожидаем.Что(Колбэки.КоличествоВыполняющихся()[0]).Равно(1);
	Ожидаем.Что(Колбэки.КоличествоОжидающих()[0]).Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьСтроковуюЛямбдуДляОбработчикаПереполнения() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
