	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем
		.Что(ПробноеДействие.ТекстВнутреннейОшибки(), "Текст внутренней ошибки должен содержать ожидаемый текст")
		.Содержит("Обработчик переполнения вызван");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьДополнительныеПараметрыВДелегатОбработчикаПереполнения() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияПараллелизма();

	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Стратегия.УстановитьОбработчикПереполнения(
		Новый Действие(Колбэки, "ПослеПереполненияСМаркером"),
		"marker"
	);

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомОграниченияПараллелизма(Стратегия, ВложеннаяОперация);
	Операция = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Колбэки.Маркеры().Количество(), "Количество маркеров должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.Маркеры()[0], "Маркер должен быть равен ожидаемому значению").Равно("marker");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВозвращатьКоличествоВыполняющихсяВоВремяЗанятогоСлота() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(500);
	Операция = Новый Действие(Сценарий, "Успех");

	// Действие
	Задача = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция)
	);

	КоличествоСталоЕдиницей = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача <> Неопределено, "Фоновое задание должно быть создано").ЭтоИстина();
	Ожидаем.Что(КоличествоСталоЕдиницей, "Количество выполняющихся операций должно стать равным 1").ЭтоИстина();
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 1").Равно(1);

	Приостановить(600);

	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ЗапрещатьИзменениеЛимитаВоВремяВыполненияОперации() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1);
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(500);
	Операция = Новый Действие(Сценарий, "Успех");

	НовыйЛимит = Новый Массив();
	НовыйЛимит.Добавить(2);

	// Действие
	Задача = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция)
	);

	КоличествоСталоЕдиницей = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача <> Неопределено, "Фоновое задание должно быть создано").ЭтоИстина();
	Ожидаем.Что(КоличествоСталоЕдиницей, "Количество выполняющихся операций должно стать равным 1").ЭтоИстина();

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("УстановитьЛимитПараллелизма", НовыйЛимит)
		.ВыбрасываетИсключение("Нельзя менять ограничения параллелизма во время выполнения или ожидания операций.");

	Приостановить(600);

	Ожидаем.Что(Стратегия.ЛимитПараллелизма(), "Лимит параллелизма должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_РазрешатьНеБолееДвухПараллельныхОперацийПриЛимитеДва() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(2);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(500);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийВторойОперации.УстановитьЗадержку(500);
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	СценарийТретьейОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция3 = Новый Действие(СценарийТретьейОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОбаСлотаЗаняты = ДождатьсяКоличествоВыполняющихся(Стратегия, 2);

	// Проверка
	Ожидаем.Что(ПервыйСлотЗанят, "Первый слот должен быть занят").ЭтоИстина();
	Ожидаем.Что(ОбаСлотаЗаняты, "Оба слота должны быть заняты").ЭтоИстина();
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 2").Равно(2);

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция3))
		.ВыбрасываетИсключение("Превышен лимит параллелизма");

	Ожидаем.Что(СценарийТретьейОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 0").Равно(0);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();

	Ожидаем.Что(СценарийПервойОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(СценарийВторойОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПомещатьОперациюВОчередьИЗапускатьЕеПослеОсвобожденияСлота() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 1);

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(400);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОперацияПоставленаВОчередь = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	// Проверка
	Ожидаем.Что(Задача1 <> Неопределено, "Фоновое задание должно быть создано").ЭтоИстина();
	Ожидаем.Что(Задача2 <> Неопределено, "Фоновое задание должно быть создано").ЭтоИстина();
	Ожидаем.Что(ПервыйСлотЗанят, "Первый слот должен быть занят").ЭтоИстина();
	Ожидаем.Что(ОперацияПоставленаВОчередь, "Операция должна быть поставлена в очередь").ЭтоИстина();
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 1").Равно(1);
	Ожидаем.Что(Стратегия.КоличествоОжидающих(), "Количество ожидающих операций должно быть равно 1").Равно(1);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(СценарийПервойОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(СценарийВторойОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих(), "Количество ожидающих операций должно быть равно 0").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ОтклонятьОперациюПриПереполненииОчереди() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиОграниченияПараллелизма();

	Стратегия = Новый СтратегияОграниченияПараллелизма(1, 1);
	Стратегия.УстановитьОбработчикПереполнения(Новый Действие(Колбэки, "ПослеПереполнения"));

	СценарийПервойОперации = Новый ТестовыеДействияОтказоустойчивости();
	СценарийПервойОперации.УстановитьЗадержку(400);
	Операция1 = Новый Действие(СценарийПервойОперации, "Успех");

	СценарийВторойОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция2 = Новый Действие(СценарийВторойОперации, "Успех");

	СценарийТретьейОперации = Новый ТестовыеДействияОтказоустойчивости();
	Операция3 = Новый Действие(СценарийТретьейОперации, "Успех");

	// Действие
	Задача1 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция1)
	);

	ПервыйСлотЗанят = ДождатьсяКоличествоВыполняющихся(Стратегия, 1);

	Задача2 = ФоновыеЗадания.Выполнить(
		Стратегия,
		"Применить",
		ПомощникТестирования.ПараметрыИсполнения(Операция2)
	);

	ОчередьЗаполнена = ДождатьсяКоличествоОжидающих(Стратегия, 1);

	// Проверка
	Ожидаем.Что(ПервыйСлотЗанят, "Первый слот должен быть занят").ЭтоИстина();
	Ожидаем.Что(ОчередьЗаполнена, "Очередь должна быть заполнена").ЭтоИстина();

	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция3))
		.ВыбрасываетИсключение("Превышен лимит параллелизма");

	Ожидаем.Что(Колбэки.ЛимитыПараллелизма().Количество(), "Количество значений лимита параллелизма должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыПараллелизма()[0], "Лимит параллелизма должен быть равен 1").Равно(1);
	Ожидаем.Что(Колбэки.ЛимитыОчереди()[0], "Лимит очереди должен быть равен 1").Равно(1);
	Ожидаем.Что(Колбэки.КоличествоВыполняющихся()[0], "Количество выполняющихся операций должно быть равно 1").Равно(1);
	Ожидаем.Что(Колбэки.КоличествоОжидающих()[0], "Количество ожидающих операций должно быть равно 1").Равно(1);
	Ожидаем.Что(СценарийТретьейОперации.СчетчикВызовов(), "Счетчик вызовов должен быть равен 0").Равно(0);

	Ожидаем.Что(Задача1.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача2.ОжидатьЗавершения(5000), "Фоновое задание должно завершиться").ЭтоИстина();
	Ожидаем.Что(Задача1.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(Задача2.ИнформацияОбОшибке = Неопределено, "Ошибка фонового задания должна отсутствовать").ЭтоИстина();
	Ожидаем.Что(Стратегия.КоличествоВыполняющихся(), "Количество выполняющихся операций должно быть равно 0").Равно(0);
	Ожидаем.Что(Стратегия.КоличествоОжидающих(), "Количество ожидающих операций должно быть равно 0").Равно(0);

