&Тест
Процедура ТестДолжен_ПовторятьОперациюДоУспеха() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПовтора(3);

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(2);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 3").Равно(3);

КонецПроцедуры

&Тест
