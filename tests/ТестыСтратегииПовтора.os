&Тест
Процедура ТестДолжен_СтроитьЛинейнуюЗадержкуИВызыватьОбработчикПовтора() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(3)
		.УстановитьЗадержку(2)
		.УстановитьТипЗадержки(ТипыРасчетаЗадержки.Линейная)
		.УстановитьОбработчикПовтора(Новый Действие(Колбэки, "ПослеПовтора"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Задержки = Колбэки.Задержки();
	НомераПопыток = Колбэки.НомераПопыток();

	Ожидаем.Что(Задержки, "Список задержек должен иметь длину 3").ИмеетДлину(3);
	Ожидаем.Что(Задержки[0], "Задержка должна быть равна 2").Равно(2);
	Ожидаем.Что(Задержки[1], "Задержка должна быть равна 4").Равно(4);
	Ожидаем.Что(Задержки[2], "Задержка должна быть равна 6").Равно(6);
	Ожидаем.Что(НомераПопыток[0], "Номер попытки должен быть равен 0").Равно(0);
	Ожидаем.Что(НомераПопыток[1], "Номер попытки должен быть равен 1").Равно(1);
	Ожидаем.Что(НомераПопыток[2], "Номер попытки должен быть равен 2").Равно(2);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ИспользоватьВычислениеЗадержкиВместоВстроенногоРасчета() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(1)
		.УстановитьЗадержку(50)
		.УстановитьВычислениеЗадержки("(Контекст) -> 7")
		.УстановитьОбработчикПовтора(Новый Действие(Колбэки, "ПослеПовтора"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Задержки = Колбэки.Задержки();
	
	Ожидаем.Что(Задержки.Количество(), "Количество задержек должно быть равно 1").Равно(1);
	Ожидаем.Что(Задержки[0], "Задержка должна быть равна 7").Равно(7);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьДлительностьВыполненияОперацииВКонтекстПовтора() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(1)
		.УстановитьЗадержку(0)
		.УстановитьОбработчикПовтора(Новый Действие(Колбэки, "ПослеПовтора"));
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	Сценарий.УстановитьЗадержку(100);
	
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	ДлительностиВыполнения = Колбэки.ДлительностиВыполнения();

	Ожидаем.Что(ДлительностиВыполнения.Количество(), "Количество замеров длительности выполнения должно быть равно 1").Равно(1);
	Ожидаем.Что(ДлительностиВыполнения[0], "Длительность выполнения должна быть больше или равна 100").БольшеИлиРавно(100);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьСледующуюПопыткуИОставшиесяПопыткиВКонтекстПовтора() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(2)
		.УстановитьЗадержку(0)
		.УстановитьОбработчикПовтора(Новый Действие(Колбэки, "ПослеПовтора"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);	
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	СледующиеПопытки = Колбэки.СледующиеПопытки();
	ПопытокОсталось = Колбэки.ПопытокОсталось();

	Ожидаем.Что(СледующиеПопытки.Количество(), "Количество следующих попыток должно быть равно 2").Равно(2);
	Ожидаем.Что(ПопытокОсталось.Количество(), "Количество оставшихся попыток должно быть равно 2").Равно(2);
	Ожидаем.Что(СледующиеПопытки[0], "Следующая попытка должна быть равна 1").Равно(1);
	Ожидаем.Что(СледующиеПопытки[1], "Следующая попытка должна быть равна 2").Равно(2);
	Ожидаем.Что(ПопытокОсталось[0], "Количество оставшихся попыток должно быть равно 2").Равно(2);
	Ожидаем.Что(ПопытокОсталось[1], "Количество оставшихся попыток должно быть равно 1").Равно(1);

КонецПроцедуры

