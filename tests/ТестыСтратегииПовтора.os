КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьСтроковуюЛямбдуКакОперацию() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПовтора(0, 0);

	ПараметрыЛямбды = Новый Массив();
	ПараметрыЛямбды.Добавить("left");
	ПараметрыЛямбды.Добавить("right");

	// Действие
	Результат = Стратегия.Применить(
		"(ПервыйПараметр, ВторойПараметр) -> СтрШаблон(""%1:%2"", ПервыйПараметр, ВторойПараметр)",
		ПараметрыЛямбды
	);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("left:right");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ВозвращатьТекущиеНастройкиСтратегииПовтора() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(4)
		.УстановитьТипЗадержки(ТипыРасчетаЗадержки.Экспоненциальная)
		.УстановитьЗадержку(150)
		.УстановитьМаксимальнуюЗадержку(700)
		.ИспользоватьРазбросЗадержки();

	// Действие
	КоличествоПовторов = Стратегия.КоличествоПовторов();
	ТипЗадержки = Стратегия.ТипЗадержки();
	Задержка = Стратегия.Задержка();
	МаксимальнаяЗадержка = Стратегия.МаксимальнаяЗадержка();
	ИспользуетсяРазбросЗадержки = Стратегия.ИспользуетсяРазбросЗадержки();

	// Проверка
	Ожидаем.Что(КоличествоПовторов, "Значение должно быть равно 4").Равно(4);
	Ожидаем
		.Что(ТипЗадержки, "Тип задержки должен быть равен ожидаемому значению")
		.Равно(ТипыРасчетаЗадержки.Экспоненциальная);
	Ожидаем.Что(Задержка, "Задержка должна быть равна 150").Равно(150);
	Ожидаем.Что(МаксимальнаяЗадержка, "Максимальная задержка должна быть равна 700").Равно(700);
	Ожидаем
		.Что(ИспользуетсяРазбросЗадержки, "Признак использования разброса задержки должен быть истинным")
		.ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьПараметрыВДействиеОперации() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПовтора(0, 0);
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "УспехСПараметрами");

	ПараметрыОперации = Новый Массив();
	ПараметрыОперации.Добавить("left");
	ПараметрыОперации.Добавить("right");

	// Действие
	Результат = Стратегия.Применить(Операция, ПараметрыОперации);

	// Проверка
	Ожидаем.Что(Результат, "Результат должен быть равен ожидаемому значению").Равно("left:right");
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Счетчик вызовов должен быть равен 1").Равно(1);

КонецПроцедуры

