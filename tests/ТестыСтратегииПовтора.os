&Тест
Процедура ТестДолжен_ПовторятьПоНеудачномуРезультату() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(3)
		.УстановитьЗадержку(0)
		.УстановитьУсловиеПовтора("КонтекстПовтора -> КонтекстПовтора.Результат() = ""fail""");

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьКоличествоНеудачныхРезультатовДоУспеха(2);
	Сценарий.УстановитьНеудачныйРезультат("fail");
	Сценарий.УстановитьРезультат("ok");

	Операция = Новый Действие(Сценарий, "НестабильныйРезультат");

	// Действие
	Результат = Стратегия.Применить(Операция);

	// Проверка
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(Сценарий.СчетчикВызовов()).Равно(3);

КонецПроцедуры

&Тест
Процедура ТестДолжен_СтроитьЛинейнуюЗадержкуИВызыватьОбработчикПовтора() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(3)
		.УстановитьЗадержку(2)
		.УстановитьТипЗадержки(ТипыРасчетаЗадержки.Линейная)
		.УстановитьОбработчикПовтора(Новый Действие(Колбэки, "ПослеПовтора"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Задержки = Колбэки.Задержки();
	НомераПопыток = Колбэки.НомераПопыток();

	Ожидаем.Что(Задержки).ИмеетДлину(3);
	Ожидаем.Что(Задержки[0]).Равно(2);
	Ожидаем.Что(Задержки[1]).Равно(4);
	Ожидаем.Что(Задержки[2]).Равно(6);
	Ожидаем.Что(НомераПопыток[0]).Равно(0);
	Ожидаем.Что(НомераПопыток[1]).Равно(1);
	Ожидаем.Что(НомераПопыток[2]).Равно(2);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ИспользоватьВычислениеЗадержкиВместоВстроенногоРасчета() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(1)
		.УстановитьЗадержку(50)
		.УстановитьВычислениеЗадержки("(Контекст) -> 7")
		.УстановитьОбработчикПовтора(Новый Действие(Колбэки, "ПослеПовтора"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Задержки = Колбэки.Задержки();
	
	Ожидаем.Что(Задержки.Количество()).Равно(1);
	Ожидаем.Что(Задержки[0]).Равно(7);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьДлительностьВыполненияОперацииВКонтекстПовтора() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПовтора();

	Стратегия = Новый СтратегияПовтора()
		.УстановитьМаксимумПовторов(1)
		.УстановитьЗадержку(0)
