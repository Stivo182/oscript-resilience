&Тест
Процедура ТестДолжен_ПередаватьПараметрыВДействиеОперации() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПовтора(0, 0);
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "УспехСПараметрами");

	ПараметрыОперации = Новый Массив();
	ПараметрыОперации.Добавить("left");
	ПараметрыОперации.Добавить("right");

	// Действие
	Результат = Стратегия.Применить(Операция, ПараметрыОперации);

	// Проверка
	Ожидаем.Что(Результат).Равно("left:right");
	Ожидаем.Что(Сценарий.СчетчикВызовов()).Равно(1);

КонецПроцедуры

