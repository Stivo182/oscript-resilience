		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Задержки = Колбэки.Задержки();

	Ожидаем.Что(Задержки.Количество(), "Количество задержек должно быть равно 2").Равно(2);
	Ожидаем.Что(Задержки[0], "Задержка должна быть равна 10").Равно(10);
	Ожидаем.Что(Задержки[1], "Задержка должна быть равна 20").Равно(20);

КонецПроцедуры

