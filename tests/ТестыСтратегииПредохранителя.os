&Тест
Процедура ТестДолжен_ВалидироватьПараметрыПредохранителя() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПредохранителя();

	ПараметрыПорога = Новый Массив();
	ПараметрыПорога.Добавить(0);

	ПараметрыРазмыкания = Новый Массив();
	ПараметрыРазмыкания.Добавить(0);

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия)
		.Метод("УстановитьПорогОшибок", ПараметрыПорога)
		.ВыбрасываетИсключение("Порог ошибок должен быть больше нуля.");

	Ожидаем
		.Что(Стратегия)
		.Метод("УстановитьДлительностьРазмыкания", ПараметрыРазмыкания)
		.ВыбрасываетИсключение("Длительность размыкания должна быть больше нуля.");

