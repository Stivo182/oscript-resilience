// Флаки-тест
&Тест
Процедура ТестДолжен_РазрешатьТолькоОднуПробнуюПопыткуПриПараллельныхВызовах() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПредохранителя(1, 100);
	
	СценарийОшибки = Новый ТестовыеДействияОтказоустойчивости();
	ОперацияОшибки = Новый Действие(СценарийОшибки, "ВсегдаОшибка");
	
	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	СценарийУспеха.УстановитьЗадержку(200);
	ОперацияУспеха = Новый Действие(СценарийУспеха, "Успех");
	
	КоличествоПараллельныхЗадач = 10;

	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(ОперацияОшибки))
		.ВыбрасываетИсключение("Всегда ошибка.");

	Приостановить(150);
	
	// Действие
	Задачи = ПомощникТестирования.ЗапуститьПараллельныеВызовыСтратегии(
		Стратегия,
		ОперацияУспеха,
		КоличествоПараллельныхЗадач
	);

	Статистика = СобратьСтатистикуФоновыхЗаданий(Задачи, "Пробный вызов уже выполняется");

	// Проверка
	Ожидаем.Что(Статистика.Успешных, "Количество успешных вызовов не совпадает").Равно(1);
	Ожидаем.Что(Статистика.ОжидаемыхОшибок, "Количество ожидаемых ошибок не совпадает").Равно(КоличествоПараллельныхЗадач - 1);
	Ожидаем.Что(Статистика.НеожиданныеОшибки.Количество(), "Количество неожиданных ошибок не совпадает").Равно(0);
	Ожидаем.Что(СценарийУспеха.СчетчикВызовов(), "Счетчик вызовов не совпадает").Равно(1);
	Ожидаем.Что(Стратегия.Состояние(), "Состояние стратегии не совпадает").Равно(СостоянияПредохранителя.Закрыт);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СобратьСтатистикуФоновыхЗаданий(Задачи, ОжидаемыйТекстОшибки)

	Статистика = Новый Структура("Успешных, ОжидаемыхОшибок, НеожиданныеОшибки", 0, 0, Новый Массив());

	Для Каждого Задание Из Задачи Цикл
		Если Не Задание.ОжидатьЗавершения(5000) Тогда
			ВызватьИсключение "Фоновое задание не завершилось вовремя.";
		КонецЕсли;

		Если Задание.ИнформацияОбОшибке = Неопределено Тогда
			Статистика.Успешных = Статистика.Успешных + 1;
			Продолжить;
		КонецЕсли;

		ТекстОшибки = ПодробноеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
		
		Если СтрНайти(ТекстОшибки, ОжидаемыйТекстОшибки) > 0 Тогда
			Статистика.ОжидаемыхОшибок = Статистика.ОжидаемыхОшибок + 1;
		Иначе
			Статистика.НеожиданныеОшибки.Добавить(ТекстОшибки);
		КонецЕсли;
	КонецЦикла;

	Возврат Статистика;

КонецФункции

#КонецОбласти
