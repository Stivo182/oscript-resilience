&Тест
Процедура ТестДолжен_ВызыватьОбработчикРазмыканияПриДостиженииПорогаОшибок() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиПредохранителя();

	Стратегия = Новый СтратегияПредохранителя(2, 180);
	Стратегия.УстановитьОбработчикРазмыкания(Новый Действие(Колбэки, "ПослеРазмыкания"));

	СценарийОшибки = Новый ТестовыеДействияОтказоустойчивости();
	СценарийОшибки.УстановитьОшибокДоУспеха(10);
	ОперацияОшибки = Новый Действие(СценарийОшибки, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(ОперацияОшибки))
		.ВыбрасываетИсключение("Ошибка на попытке");

	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(ОперацияОшибки))
		.ВыбрасываетИсключение("Ошибка на попытке");

	// Проверка
	Ожидаем.Что(Колбэки.ПорогиОшибок().Количество()).Равно(1);
	Ожидаем.Что(Колбэки.ПорогиОшибок()[0]).Равно(2);
	Ожидаем.Что(Колбэки.КоличествоОшибокПодряд()[0]).Равно(2);
	Ожидаем.Что(Колбэки.ДлительностиРазмыкания()[0]).Равно(180);
	Ожидаем.Что(Колбэки.Состояния()[0]).Равно(СостоянияПредохранителя.Разомкнут);
	Ожидаем.Что(Колбэки.ЕстьДанныеОшибки()[0]).Равно(Истина);

КонецПроцедуры

