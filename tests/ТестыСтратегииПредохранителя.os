#Область Тесты

&Тест
Процедура ТестДолжен_ПереводитьПредохранительВРазомкнутоеСостояниеИБлокироватьВызовы() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПредохранителя(2, 200);
	
	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьОшибокДоУспеха(10);
	Операция = Новый Действие(Сценарий, "Нестабильное");

	// Действие
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	Ожидаем.Что(Стратегия.Состояние()).Равно(СостоянияПредохранителя.Закрыт);

	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Ошибка на попытке");

	Ожидаем.Что(Стратегия.Состояние()).Равно(СостоянияПредохранителя.Разомкнут);

	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Предохранитель временно разомкнут");

	Приостановить(250);

	// Проверка
	Ожидаем.Что(Сценарий.СчетчикВызовов()).Равно(2);
	Ожидаем.Что(Стратегия.Состояние()).Равно(СостоянияПредохранителя.Полуразомкнут);

КонецПроцедуры

&Тест
Процедура ТестДолжен_БлокироватьВторойВызовВПолуразомкнутомСостоянииПокаИдетПробный() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияПредохранителя(1, 120);

	СценарийОшибки = Новый ТестовыеДействияОтказоустойчивости();
	СценарийОшибки.УстановитьОшибокДоУспеха(10);
	ОперацияОшибки = Новый Действие(СценарийОшибки, "Нестабильное");

	СценарийУспеха = Новый ТестовыеДействияОтказоустойчивости();
	ВложеннаяОперация = Новый Действие(СценарийУспеха, "Успех");
	ПробноеДействие = Новый ТестовоеДействиеСВложеннымВызовомПредохранителя(Стратегия, ВложеннаяОперация);
	ОперацияПробы = Новый Действие(ПробноеДействие, "ВыполнитьСВложеннымЗапуском");

	// Действие
	Ожидаем
		.Что(Стратегия)
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(ОперацияОшибки))
		.ВыбрасываетИсключение("Ошибка на попытке");

	Ожидаем.Что(Стратегия.Состояние()).Равно(СостоянияПредохранителя.Разомкнут);

	Приостановить(140);

	Ожидаем.Что(Стратегия.Состояние()).Равно(СостоянияПредохранителя.Полуразомкнут);

	Результат = Стратегия.Применить(ОперацияПробы);

	// Проверка
	Ожидаем.Что(Результат).Равно("ok");
	Ожидаем.Что(ПробноеДействие.ВнутреннийСбойПойман()).ЭтоИстина();
	Ожидаем.Что(СценарийУспеха.СчетчикВызовов()).Равно(0);
	Ожидаем.Что(Стратегия.Состояние()).Равно(СостоянияПредохранителя.Закрыт);

КонецПроцедуры

