КонецПроцедуры

&Тест
Процедура ТестДолжен_ПоддерживатьЛямбдуДляОбработчикаТаймаута() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияТаймаута(20);
	Стратегия.УстановитьОбработчикТаймаута("(КонтекстТаймаута) -> ВызватьИсключение ""Обработчик таймаута вызван""");

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(300);
	Операция = Новый Действие(Сценарий, "Долгое");

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("Обработчик таймаута вызван");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПередаватьДополнительныеПараметрыВДелегатОбработчикаТаймаута() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиТаймаута();

	Стратегия = Новый СтратегияТаймаута(20);
	Стратегия.УстановитьОбработчикТаймаута(
		Новый Действие(Колбэки, "ПослеТаймаутаСМаркером"),
		"marker"
	);

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(300);
	Операция = Новый Действие(Сценарий, "Долгое");

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("таймаут");

	Ожидаем.Что(Колбэки.Маркеры(), "Список маркеров должен иметь длину 1").ИмеетДлину(1);
	Ожидаем.Что(Колбэки.Маркеры()[0], "Маркер должен быть равен ожидаемому значению").Равно("marker");

КонецПроцедуры

#КонецОбласти
