КонецПроцедуры

&Тест
Процедура ТестДолжен_ВызыватьОбработчикТаймаутаПередИсключением() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиТаймаута();

	Стратегия = Новый СтратегияТаймаута(20);
	Стратегия.УстановитьОбработчикТаймаута(Новый Действие(Колбэки, "ПослеТаймаута"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Сценарий.УстановитьЗадержку(300);

	Операция = Новый Действие(Сценарий, "Долгое");

	// Действие и Проверка
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод("Применить", ПомощникТестирования.ПараметрыИсполнения(Операция))
		.ВыбрасываетИсключение("таймаут");

	Ожидаем.Что(Колбэки.Таймауты(), "Список таймаутов должен иметь длину 1").ИмеетДлину(1);
	Ожидаем.Что(Колбэки.Таймауты()[0], "Значение таймаута должно быть равно 20").Равно(20);
	Ожидаем.Что(Колбэки.ДлительностиВыполнения(), "Список длительностей должен иметь длину 1").ИмеетДлину(1);
	Ожидаем.Что(Колбэки.ДлительностиВыполнения()[0], "Длительность должна быть больше или равна 0").БольшеИлиРавно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_НеЗапускатьОперациюИНеВызыватьОбработчикТаймаутаДляУжеПрерваннойОперации() Экспорт

	// Подготовка
	Колбэки = Новый ТестовыеКолбэкиТаймаута();

	Стратегия = Новый СтратегияТаймаута(20);
	Стратегия.УстановитьОбработчикТаймаута(Новый Действие(Колбэки, "ПослеТаймаута"));

	Сценарий = Новый ТестовыеДействияОтказоустойчивости();
	Операция = Новый Действие(Сценарий, "Успех");

	СигналПрерыванияОперации = Новый СигналПрерыванияОперации();
	СигналПрерыванияОперации.ЗапроситьПрерывание("Остановлено тестом.");

	// Действие
	Ожидаем
		.Что(Стратегия, "Вызов метода стратегии должен выбрасывать ожидаемое исключение")
		.Метод(
			"Применить",
			ПомощникТестирования.ПараметрыИсполнения(Операция, Неопределено, СигналПрерыванияОперации)
		)
		.ВыбрасываетИсключение("Остановлено тестом.");

	// Проверка
	Ожидаем.Что(Сценарий.СчетчикВызовов(), "Пользовательская операция не должна запускаться").Равно(0);
	Ожидаем.Что(Колбэки.Таймауты().Количество(), "Обработчик таймаута не должен вызываться").Равно(0);
	Ожидаем.Что(Колбэки.ДлительностиВыполнения().Количество(), "Обработчик таймаута не должен вызываться").Равно(0);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ЗапрашиватьПрерываниеОперацииПриТаймауте() Экспорт

	// Подготовка
	Стратегия = Новый СтратегияТаймаута(20);
